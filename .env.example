# ===========================================
# قاعدة البيانات — MySQL (padel_db)
# ===========================================
# جميع قراءة/كتابة البيانات تتم من وإلى قاعدة البيانات المحددة في الرابط.
# تأكد أن اسم القاعدة في الرابط هو padel_db (أو أنشئها في phpMyAdmin ثم استخدم نفس الاسم).
# محلي (XAMPP): mysql://root:@localhost:3306/padel_db
# Hostinger:    mysql://user:pass@127.0.0.1/padel_db  ← استخدم 127.0.0.1 وليس localhost
DATABASE_URL=mysql://root:@localhost:3306/padel_db

# PostgreSQL (اختياري — انظر POSTGRES_SETUP.md)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/padel

# ===========================================
# الإنتاج — playtix.app (Hostinger)
# ===========================================
# الدومين: https://playtix.app
# في Environment Variables على Hostinger أضف:
#   DATABASE_URL   = mysql://USER:PASS@127.0.0.1/u502561206_padel_db
#   VITE_USE_POSTGRES = true
#   BASE_URL       = https://playtix.app  (لرابط استعادة كلمة المرور ودفع الدعوة)
#   BASE_PATH      = /app
# لا تضف VITE_API_URL — التطبيق يستخدم نفس الدومين للـ API (https://playtix.app/api)

# ===========================================
# API — للتطوير المحلي
# ===========================================
# VITE_API_URL=http://localhost:4000  (عند تشغيل الواجهة على منفذ مختلف)

# ===========================================
# Supabase — مزامنة البيانات (بديل عن PostgreSQL)
# ===========================================
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# ===========================================
# Resend — استعادة كلمة المرور
# ===========================================
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM=PlayTix <noreply@playtix.app>

# ===========================================
# إرسال الرسائل — Twilio (WhatsApp + SMS) أو Meta
# ===========================================
# راجع docs/TWILIO_MESSAGING_SETUP.md للتفاصيل الكاملة

# Twilio — أساسي (مطلوب لـ WhatsApp و SMS)
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token

# WhatsApp عبر Twilio
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   ← Sandbox للتجربة
# TWILIO_WHATSAPP_FROM=whatsapp:+15755776222   ← رقمك (بعد تفعيل WhatsApp عليه)

# SMS عبر Twilio Messaging Service (PlayTix SMS)
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx      ← من Messaging → Services → PlayTix SMS

# SMS عبر Authentica (السعودية — مفضّل للأرقام السعودية)
# AUTHENTICA_API_KEY=your_api_key               ← من portal.authentica.sa
# AUTHENTICA_SENDER_NAME=PlayTix                ← اسم المرسل المسجّل لدى Authentica

# توثيق اسم المرسل (يُضاف في نهاية كل رسالة)
# WHATSAPP_SENDER_NAME=PlayTix
# WHATSAPP_DEFAULT_COUNTRY_CODE=966            ← للأرقام المحلية (05xxxxxxxx)

# Meta (بديل لـ WhatsApp): إذا لم تُضف Twilio، يُستخدم Meta
WHATSAPP_VERIFY_TOKEN=playtix_whatsapp_verify
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
